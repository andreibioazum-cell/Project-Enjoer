<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent">
    <android.opengl.GLSurfaceView android:id="@+id/gl_view" android:layout_width="match_parent" android:layout_height="match_parent"/>
    
    <RelativeLayout android:id="@+id/game_ui" android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
        <Button android:id="@+id/btn_menu" android:layout_width="50dp" android:layout_height="50dp" android:text="≡" android:layout_margin="10dp" android:background="@drawable/btn_blue"/>
        <FrameLayout android:id="@+id/joy_base" android:layout_width="140dp" android:layout_height="140dp" android:layout_alignParentBottom="true" android:layout_marginLeft="40dp" android:layout_marginBottom="40dp" android:background="@drawable/joy_base"/>
        <View android:id="@+id/joy_stick" android:layout_width="60dp" android:layout_height="60dp" android:layout_alignLeft="@id/joy_base" android:layout_alignTop="@id/joy_base" android:layout_marginLeft="40dp" android:layout_marginTop="40dp" android:background="@drawable/joy_stick"/>
    </RelativeLayout>

    <LinearLayout android:id="@+id/menu_ui" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:background="#02050A">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ENJOER" android:textSize="50sp" android:textColor="#00BFFF"/>
        <Button android:id="@+id/btn_play" android:layout_width="200dp" android:layout_height="60dp" android:text="PLAY" android:layout_margin="10dp"/>
        <Button android:id="@+id/btn_engine" android:layout_width="200dp" android:layout_height="60dp" android:text="EDITOR"/>
    </LinearLayout>
</FrameLayout>
